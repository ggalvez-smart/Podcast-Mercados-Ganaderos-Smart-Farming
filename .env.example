# ============================================================================
# VARIABLES DE ENTORNO - Plataforma de Podcast
# ============================================================================
# Este archivo es una PLANTILLA. Copiá este archivo como ".env" (sin
# ".example") y completá los valores reales ahí. El archivo ".env" nunca
# se sube a GitHub (está en .gitignore) porque contiene datos sensibles.
# ============================================================================

# Dirección de conexión a la base de datos PostgreSQL.
# Durante el desarrollo local podés usar una base de datos gratuita en
# Neon (https://neon.tech) o Supabase (https://supabase.com).
# El formato es: postgresql://usuario:contraseña@host:puerto/nombre_basededatos
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/podcast_platform"

# Clave secreta que usa NextAuth para firmar las sesiones de forma segura.
# Generala una sola vez y no la cambies después (si la cambiás, todas las
# personas que tenían sesión iniciada van a tener que volver a loguearse).
# Para generar una clave válida, corré este comando en una terminal:
#   openssl rand -base64 32
# y pegá el resultado acá.
AUTH_SECRET="reemplazar-con-una-clave-generada"
